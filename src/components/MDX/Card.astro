---
interface Props {
  title: string;
  image?: string;
  href?: string;

  description?: string;

  meta?: string;

  category?: string;

  star?: string;

  users?: string;
}

const {
  title, image, href = "#", description, meta, category, star, users
} = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="anime-card group relative overflow-hidden rounded-xl border border-(--line-divider) bg-(--card-bg) cursor-pointer transition-all duration-300 hover:shadow-lg hover:border-(--primary)/30 hover:-translate-y-1"
>
  <!-- Poster -->
  <div class="relative aspect-2/3 overflow-hidden bg-neutral-100 dark:bg-neutral-800">
    {
   			<div class="lqip-placeholder absolute rounded-none inset-0 pointer-events-none" style="background: var(--muted)" aria-hidden="true"></div>
        <img
          src={image}
          alt={title}
          loading="lazy"
          decoding="async"
          class="h-full rounded-none w-full object-cover mt-0 mb-0 transition-all duration-500 group-hover:scale-110 opacity-0"
        />
    }
      <div class="absolute top-2 left-2 rounded-lg bg-[linear-gradient(to_top_right,#00F0FF,#B16CEA)] px-2 py-1 text-xs font-bold text-white backdrop-blur-sm">
        {category}
      </div>

      <div class="absolute top-2 right-2 flex items-center gap-1 rounded-lg bg-black/70 backdrop-blur-sm px-2 py-1 text-xs font-bold text-white">
				<svg class="h-3 w-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
					<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
				</svg>
        {star}
      </div>

      <div class="absolute bottom-2 left-2 rounded-md bg-pink-500/80 px-2 py-0.5 text-[10px] font-medium text-white backdrop-blur-sm">
        {users}
      </div>

    <div class="absolute inset-0 flex flex-col justify-end bg-linear-to-t from-black/80 via-black/40 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
      <div class="p-3">
        <p class="mb-2 line-clamp-3 text-xs leading-relaxed text-white/90">
          {description}
        </p>

        <div class="w-full rounded-lg bg-(--primary) px-3 py-1.5 text-center text-xs font-medium text-white transition-colors group-hover:bg-(--primary)/80">
          View Details
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom info -->
  <div class="p-3">
    <h3 class="mb-1 line-clamp-1 text-sm font-semibold text-neutral-900 dark:text-neutral-100" title={title}>
      {title}
    </h3>

      <div class="flex items-center justify-between text-xs text-neutral-500 dark:text-neutral-400">
        <span>{meta}</span>
      </div>
  </div>
</a>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
