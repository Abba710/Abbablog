---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import ReviewsCarousel from "@/components/pages/locker/ReviewsCarousel.astro";

import lockerScreenshot1 from "@/assets/images/Projects/lockerscreen1.png"; // Placeholder – replace with actual screenshot
import lockerScreenshot2 from "@/assets/images/Projects/lockerscreen2.png"; // Placeholder – replace with actual screenshot
import lockerIcon from "@/assets/images/Projects/icon.png"

// Base URL for Chrome Web Store (without partner code)
const BASE_CHROME_URL =
    "https://chromewebstore.google.com/detail/fagjclghcmnfinjdkdnkejodfjgkpljd?utm_source=personal_website";

const useCases = [
    { label: "YouTube videos", emoji: "🎬" },
    { label: "Movies from Shorts", emoji: "🎥" },
    { label: "TikTok collections", emoji: "📱" },
    { label: "Research", emoji: "🔬" },
    { label: "GitHub repos", emoji: "🐙" },
    { label: "ChatGPT conversations", emoji: "🤖" },
    { label: "Learning resources", emoji: "📚" },
    { label: "Shopping", emoji: "🛍️" },
    { label: "Travel", emoji: "✈️" },
    { label: "Recipes", emoji: "🍳" },
    { label: "AI tools", emoji: "🧠" },
    { label: "Design inspiration", emoji: "🎨" },
    { label: "Documentation", emoji: "📄" },
];

const extensionReplacements = [
    "Bookmark Manager",
    "Bookmark Sidebar",
    "Bookmark Organizer",
    "Session Manager",
    "Restore Tabs",
    "Private Bookmarks",
    "Cloud Sync",
    "Password Protection",
];

const customizationFeatures = [
    "Resizable cards",
    "Folders",
    "Drag & Drop",
    "Quick Search",
    "Keyboard shortcuts",
    "Panic Button",
    "Modern UI",
    "Fast navigation",
];
---
<script>
    // Captures `?aff=<id>` on first visit, remembers it, and stamps that id
    // onto every Chrome Web Store CTA on the page — on this visit and later
    // ones. Astro scripts run once on the client after the static HTML has
    // parsed, so this needs no framework hook.
    const STORAGE_KEY = 'locker-partner-id';

    const incomingAff = new URLSearchParams(window.location.search).get('aff');
    if (incomingAff) {
        localStorage.setItem(STORAGE_KEY, incomingAff);
    }

    const partnerId = localStorage.getItem(STORAGE_KEY);
    if (partnerId) {
        document.querySelectorAll('[data-chrome-cta]').forEach((link) => {
            if (!(link instanceof HTMLAnchorElement)) return;
            const url = new URL(link.href);
            url.searchParams.set('aff', partnerId);
            link.href = url.toString();
        });
    }
</script>

<MainGridLayout
    title="Locker: Bookmark Manager & Sidebar with Incognito Support"
    description="All-in-one bookmark manager for Chromium browsers. Save, organize, protect, and restore bookmarks with full Incognito support. Replace 5 extensions with 1."
>
