                </div>
            </div>

            <!-- Visual comparison – "5 → 1" -->
            <div class="flex flex-col items-center justify-center">
                <div class="flex items-center gap-6">
                    <div class="flex -space-x-3">
                        {[1, 2, 3, 4, 5].map((i) => (
                            <div
