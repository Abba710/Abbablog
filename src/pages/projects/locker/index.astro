                  <img src={lockerIcon.src} alt="Bookmark manager" />
                </div>
            </div>
            <p class="mt-4 text-sm text-neutral-500 dark:text-neutral-400">
                5 extensions → 1 integrated experience
            </p>
        </div>

    </div>

</section>

<!-- ============================================================ -->
